# =============================================================================
# Smart Parking System — backend environment variables
# Copy to .env and fill in real values:  cp .env.example .env
# =============================================================================

# --- Database ---
# Local backend + MySQL in Docker (host port 3307):
DATABASE_URL=mysql+pymysql://admin:123456@localhost:3307/parking_db
# Backend inside Docker Compose (service name `db`):
# DATABASE_URL=mysql+pymysql://admin:123456@db:3306/parking_db

# --- Auth (JWT) ---
JWT_SECRET_KEY=
JWT_EXPIRE_HOURS=3
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=10

# --- Google Maps (geocoding / nearby parking) ---
GOOGLE_MAPS_API_KEY=

# --- VietQR (bank account lookup — https://my.vietqr.io) ---
VIETQR_CLIENT_ID=
VIETQR_API_KEY=

# --- Redis (optional — wallet / caching) ---
REDIS_URL=

# --- CORS (comma-separated frontend origins) ---
CORS_ORIGINS=http://localhost:5173

# --- Feature flags ---
ENABLE_MOCK_TOPUP=false
ENABLE_HSTS=false

# --- Background jobs ---
AUTO_CHECKOUT_INTERVAL_SECONDS=30

# --- API gateway / rate limiting ---
GATEWAY_RATE_LIMIT_PER_MINUTE=600
GATEWAY_LOGIN_RATE_LIMIT_PER_MINUTE=30
GATEWAY_MAX_REQUEST_BYTES=2097152

# --- Gate / check-in policy ---
GATE_SCAN_COOLDOWN_MINUTES=5
GATE_NO_SHOW_CANCEL_RATIO=0.3
GATE_EARLY_CHECKIN_POLICY=ALLOW_WITH_EXTRA_FEE
GATE_EARLY_GRACE_MINUTES=15
